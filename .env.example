# =========================================================================
# Olokas — environment variables
# Copy to .env.local for local dev. Set in Vercel dashboard for production.
# Never commit real values; .gitignore excludes .env.local.
# =========================================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=https://olokas.com

# --- Supabase ---
# Project URL and anon key from supabase.com → Project → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only. NEVER prefix with NEXT_PUBLIC_.
# Required for cron routes, Stripe webhook, admin scripts.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# From dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Created when you `stripe listen` for dev or set up the webhook in prod
STRIPE_WEBHOOK_SECRET=
# Price IDs (created via stripe products create / stripe prices create)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_ANNUAL=

# --- Anthropic ---
# console.anthropic.com → API keys. Set $50/mo spend cap to start.
ANTHROPIC_API_KEY=

# --- Resend ---
# resend.com → API keys. Verify olokas.com domain before sending.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Olokas <hello@olokas.com>

# --- SerpAPI (Google AI Overviews) ---
# serpapi.com — free tier good for dev (250 searches/mo)
SERPAPI_KEY=

# --- Perplexity ---
# perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# --- Cron auth ---
# Random secret shared between GitHub Actions cron and /api/cron/* routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Public form endpoints ---
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/mkoyrbwk

# --- Worker (Hetzner VPS) ---
# These live in /etc/olokas-worker/.env on the VPS, not in Vercel.
# Documenting here so the worker README knows what to set.
# WORKER_DATABASE_URL=postgresql://...        # Supabase direct connection
# WORKER_POLL_INTERVAL_SEC=30
# WORKER_MAX_CONCURRENT_JOBS=4
